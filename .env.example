# ─── OBRIGATÓRIAS ─────────────────────────────────────────
# Token do seu bot no Telegram (criado via @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Seu ID de usuário no Telegram (para receber notificações)
ALLOWED_TELEGRAM_USER_ID=123456789

# Personal Access Token da Vercel (criado em vercel.com/account/tokens)
VERCEL_TOKEN=seu_vercel_token

# ID do projeto ApexEnem na Vercel (encontrado nas configurações do projeto)
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxx

# Token do GitHub com permissão de push no repositório ApexEnem
GITHUB_TOKEN=github_pat_xxxxxxxx

# URL do repositório ApexEnem
REPO_URL=https://github.com/Fardinando/ApexEnem.git

# ─── OLLAMA (primário) ────────────────────────────────────
# URL do servidor Ollama (ex: http://SEU-IP:11434 via Cloudflare Tunnel)
OLLAMA_HOST=http://localhost:11434

# Modelo Ollama
OLLAMA_MODEL=llama3.1

# Timeout em segundos para chamadas Ollama
OLLAMA_TIMEOUT=10

# ─── FALLBACK API (Groq - usado se Ollama offline) ────────
# Chave da API Groq: https://console.groq.com/keys
AI_API_KEY=

# URL base da API de fallback
AI_API_BASE_URL=https://api.groq.com/openai/v1

# Modelo de fallback
AI_MODEL=llama3-8b-8192

# ─── ADMIN SUPREME (credencial inicial) ────────────────────
# Usuário e senha do admin supreme (criado automaticamente na primeira execução)
ADMIN_USER=supreme
ADMIN_PASS=escolha_uma_senha_forte

# ─── SUPABASE (correção de dados do ApexEnem) ────────────
# Se configurado, o ApexGuardian poderá consultar e corrigir dados no Supabase
SUPABASE_URL=
SUPABASE_KEY=

# ─── TURSO (banco persistente - 9GB grátis) ──────────────
# Se configurado, usa Turso em vez de SQLite local (que reseta no deploy)
# Crie em: https://turso.tech
# URL do banco (libsql://...)
TURSO_DB_URL=

# Token de autenticação
TURSO_AUTH_TOKEN=

# ─── OPCIONAIS ─────────────────────────────────────────────
# Caminho do banco SQLite (usado apenas se TURSO_DB_URL estiver vazio)
DATABASE_PATH=data/apexguardian.db

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Chave secreta para sessões (gere uma string aleatória)
SESSION_SECRET=change-me-to-a-random-string
